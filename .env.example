# IBM watsonx.ai Configuration
WATSONX_API_KEY=your_ibm_cloud_api_key_here
WATSONX_PROJECT_ID=your_watsonx_project_id_here
WATSONX_URL=https://au-syd.ml.cloud.ibm.com

# IBM Granite Model ID
GRANITE_MODEL_ID=meta-llama/llama-3-3-70b-instruct

# Flask Configuration
FLASK_SECRET_KEY=your_super_secret_flask_key_change_this
FLASK_DEBUG=False
FLASK_PORT=5000

# RAG / FAISS Configuration
FAISS_INDEX_PATH=faiss_index
PDF_UPLOAD_FOLDER=uploads/pdfs
MAX_CONTENT_LENGTH=16777216

# Embedding Model (HuggingFace - free, no API key needed)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# App Configuration
APP_NAME=Street Vendor Digitalization Agent
APP_VERSION=1.0.0
DEFAULT_LANGUAGE=en
